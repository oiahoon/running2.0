{
  "name": "running-page-2.0",
  "version": "2.0.0",
  "private": true,
  "description": "A modern running data visualization platform",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node ../../scripts/prepare-vercel-db.js && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "migrate": "node ../../scripts/migrate-data.js",
    "db:init": "node -e \"require('./src/lib/database/connection').getDatabase(); console.log('Database initialized')\"",
    "db:migrate": "npm run migrate",
    "prepare-db": "node ../../scripts/prepare-vercel-db.js"
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.0",
    "next": "^16.1.6",
    "next-themes": "^0.2.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.1.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sharp": "0.33.1",
    "ts-node": "^10.9.2"
  }
}
